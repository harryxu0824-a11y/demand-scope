# AI Builder Space (OpenAI-compatible gateway)
AI_BUILDER_TOKEN=sk_your_new_token_here
AI_BUILDER_BASE_URL=https://space.ai-builders.com/backend

# Reddit (leave blank until you have PRAW credentials)
REDDIT_SOURCE=mock
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=demand-scope/0.1 by /u/your_reddit_username

# Model allocation per pipeline step (override individually)
MODEL_REFRAMER=gemini-2.5-pro
MODEL_ADEQUACY=gemini-2.5-pro
MODEL_QUERY_PLANNER=gemini-3-flash-preview
MODEL_SIGNAL_FILTER=deepseek
MODEL_ANALYZER=gemini-2.5-pro
MODEL_CRITIC=gpt-5

# App auth: comma-separated tokens. Each friend gets their own.
APP_ACCESS_TOKENS=token_harry_change_me
DAILY_QUOTA_PER_TOKEN=20
MAX_INPUT_CHARS_PER_ANALYSIS=40000

# CORS allowlist (comma-separated). Add your Vercel URL before deploy.
APP_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3100

# Cache
CACHE_DIR=./cache
CACHE_TTL_DAYS=7
